# .bandit — Hancock CI whitelist (approved by 0ai-Cyberviser)
# Only production code can fail CI. Tests are explicitly ignored.
targets:
  - .
skips:
  - B110  # try/except/pass — already replaced in production
  - B310  # urlopen — already hardened with SSL context
  - B404  # subprocess import — tests only
  - B603  # subprocess without shell=True — tests only
  - B105  # hardcoded password in tests
  - B106  # hardcoded funcarg in tests
  - B104  # bind all interfaces — test only
exclude_dirs:
  - tests
  - qa
  - projects
  - .venv
  - __pycache__
  - clients
  - docs
  - fuzz
  - .github
severity: high   # Only High issues fail CI
confidence: high
