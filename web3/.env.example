# Private key for deployment (DO NOT COMMIT)
PRIVATE_KEY=your_private_key_here

# RPC URLs
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_RPC_URL=https://polygon-rpc.com

# API Keys
POLYGONSCAN_API_KEY=your_polygonscan_api_key
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_for_gas_reporter

# Contract Addresses (filled after deployment)
NEXT_PUBLIC_CVT_TOKEN_ADDRESS=
NEXT_PUBLIC_CVT_STAKING_ADDRESS=
NEXT_PUBLIC_CVT_GOVERNANCE_ADDRESS=

# Frontend Configuration
NEXT_PUBLIC_CHAIN_ID=80001
NEXT_PUBLIC_NETWORK_NAME=mumbai
NEXT_PUBLIC_EXPLORER_URL=https://mumbai.polygonscan.com

# Gas Reporting
REPORT_GAS=false
