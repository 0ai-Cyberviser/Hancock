FROM kalilinux/kali-rolling

RUN apt update && apt install -y \
    nmap sqlmap metasploit-framework python3 python3-pip python3-venv

RUN pip install --no-cache-dir --break-system-packages \
    langgraph langchain langchain-core langchain-community pydantic \
    faiss-cpu huggingface-hub

COPY hancock_langgraph.py /app/
WORKDIR /app
CMD ["python3", "hancock_langgraph.py"]
