FROM kalilinux/kali-rolling

RUN apt update && apt install -y \
    nmap sqlmap metasploit-framework git python3-yaml docker.io \
    python3 python3-pip python3-venv python3-requests

RUN pip install --no-cache-dir --break-system-packages \
    langgraph langchain langchain-core langchain-community pydantic \
    chromadb beautifulsoup4 google-auth google-auth-oauthlib \
    google-api-python-client

COPY hancock_langgraph.py /app/
COPY zero_day_guard.py /app/
COPY orchestration_controller.py /app/
COPY input_validator.py /app/

WORKDIR /app

CMD ["python", "hancock_langgraph.py"]
