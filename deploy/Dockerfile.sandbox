FROM kalilinux/kali-rolling

# Install system tools + Docker + Python stack
RUN apt update && apt install -y \
    nmap sqlmap metasploit-framework \
    docker.io python3 python3-pip python3-venv python3-requests

# Full LangGraph + ChromaDB stack for ALL 9 modes + hybrid RAG
RUN pip install --no-cache-dir --break-system-packages \
    langgraph \
    langchain \
    langchain-core \
    langchain-community \
    pydantic \
    chromadb

# Copy LangGraph core
COPY hancock_langgraph.py /app/

WORKDIR /app
CMD ["python3", "hancock_langgraph.py"]
