FROM kalilinux/kali-rolling:latest

RUN apt update && apt install -y \
    nmap sqlmap metasploit-framework git python3-yaml docker.io \
    python3 python3-pip python3-venv python3-requests \
    && ln -s /usr/bin/python3 /usr/bin/python \
    && apt clean && rm -rf /var/lib/apt/lists/*

# Pre-install LangGraph + deps
RUN pip install --no-cache-dir --break-system-packages \
    langgraph langchain langchain-core langchain-community \
    pydantic chromadb beautifulsoup4 google-auth google-auth-oauthlib google-api-python-client

COPY hancock_langgraph.py hancock_zeroday_finder.py hancock_zeroday_guard.py orchestration_controller.py input_validator.py /app/
WORKDIR /app
