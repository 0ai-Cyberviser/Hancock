FROM kalilinux/kali-rolling

# Install system tools + explicit Python 3 stack
RUN apt update && apt install -y \
    nmap \
    sqlmap \
    metasploit-framework \
    python3 \
    python3-pip \
    python3-venv \
    python3-requests

# Install full LangGraph + LangChain stack for ALL 9 modes (agentic core)
RUN pip install --no-cache-dir --break-system-packages \
    langgraph \
    langchain \
    langchain-core \
    langchain-community \
    pydantic

# Copy LangGraph core
COPY hancock_langgraph.py /app/

WORKDIR /app

# Use python3 (Kali default)
CMD ["python3", "hancock_langgraph.py"]
