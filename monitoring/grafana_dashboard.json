{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": "hancock-overview-v1",
  "title": "Hancock \u2014 Security AI Agent",
  "tags": [
    "hancock",
    "security",
    "ai"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Incoming request rate per endpoint.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(hancock_requests_total[2m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Percentage of 5xx responses over total requests.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(hancock_requests_total{status=~\"5..\"}[2m])) / sum(rate(hancock_requests_total[2m])) * 100",
          "legendFormat": "error %",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Duration p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Request latency percentiles.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(hancock_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(hancock_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(hancock_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p99",
          "refId": "C",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "Model Response Time p50 / p99",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Model inference latency percentiles.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(hancock_model_response_time_seconds_bucket[2m])) by (le, model))",
          "legendFormat": "{{model}} p50",
          "refId": "A",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(hancock_model_response_time_seconds_bucket[2m])) by (le, model))",
          "legendFormat": "{{model}} p99",
          "refId": "B",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "Rate Limit Exceeded (events/s)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 8,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Rate at which requests are rejected by the rate limiter.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(hancock_rate_limit_exceeded_total[2m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 6,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 16,
        "w": 8,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Resident set size of the Hancock process.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "hancock_memory_usage_bytes",
          "legendFormat": "RSS",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 16,
        "w": 8,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Current number of open HTTP connections.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "hancock_active_connections",
          "legendFormat": "connections",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 8,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": "Prometheus",
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(hancock_requests_total)",
          "legendFormat": "total",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 9,
      "title": "Total Rate-Limit Events",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": "Prometheus",
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(hancock_rate_limit_exceeded_total)",
          "legendFormat": "total",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 10,
      "title": "p99 Request Duration",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": "Prometheus",
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(hancock_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 11,
      "title": "Current Memory (RSS)",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": "Prometheus",
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "hancock_memory_usage_bytes",
          "legendFormat": "RSS",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "links": []
}
