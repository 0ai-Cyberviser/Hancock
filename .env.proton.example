# Proton Mail Bridge environment template for Hancock
# Copy to .env locally only. Do NOT commit real credentials.

PROTON_MAIL_ACCOUNT=cyberviser@proton.me
PROTON_BRIDGE_HOST=127.0.0.1
PROTON_BRIDGE_IMAP_PORT=<bridge_imap_port>
PROTON_BRIDGE_SMTP_PORT=<bridge_smtp_port>
PROTON_BRIDGE_USERNAME=<bridge_username>
PROTON_BRIDGE_PASSWORD=<secret_manager_reference_only>

# CyberViser Google Workspace identities known to the Hancock ops workspace.
# These are identity labels only, not proof of delegated mailbox access.
CYBERVISER_MAIL_PRIMARY=cyberviser@cyberviserai.com
CYBERVISER_MAIL_ADMIN=0ai@cyberviserai.com
CYBERVISER_MAIL_OWNER=johnnywatters@cyberviserai.com
CYBERVISER_MAIL_OPS=juanaquas@cyberviserai.com
CYBERVISER_MAIL_EXEC=ceo@cyberviserai.com

# Hancock mail adapter behavior gates
HANCOCK_MAIL_READ_SCOPE=explicit-request-only
HANCOCK_MAIL_DRAFT_MODE=true
HANCOCK_MAIL_SEND_REQUIRES_CONFIRMATION=true
HANCOCK_MAIL_DELETE_REQUIRES_CONFIRMATION=true
